<Page
  x:Class="HeliosToolkit.App.Views.Pages.SettingsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignHeight="700"
  d:DesignWidth="1100"
  Title="Settings"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Page.Resources>

  <Grid Margin="32,24,20,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Settings" />
      <TextBlock
        Margin="0,4,0,0"
        Style="{StaticResource PageSubtitleTextStyle}"
        Text="{Binding ViewModel.VersionText, Mode=OneWay}" />
    </StackPanel>

    <ScrollViewer Grid.Row="1" Margin="0,18,0,0" Padding="0,0,12,24" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <ui:Card Margin="0,0,0,12" Padding="20">
          <StackPanel>
            <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Updates" />
            <TextBlock
              Margin="0,4,0,12"
              Style="{StaticResource PageSubtitleTextStyle}"
              Text="Helios checks the GitHub Releases page. It never installs anything automatically." />
            <StackPanel Orientation="Horizontal">
              <ui:Button
                Margin="0,0,8,0"
                Command="{Binding ViewModel.CheckForUpdatesCommand}"
                Content="Check for updates"
                Icon="{ui:SymbolIcon ArrowDownload24}" />
              <ui:Button
                Margin="0,0,8,0"
                Command="{Binding ViewModel.RefreshManifestCommand}"
                Content="Refresh driver manifest"
                Icon="{ui:SymbolIcon ArrowSync24}" />
              <ui:Button
                Margin="0,0,8,0"
                Appearance="Primary"
                Command="{Binding ViewModel.InstallUpdateCommand}"
                Content="Install update now"
                Icon="{ui:SymbolIcon ArrowCircleUp24}"
                Visibility="{Binding ViewModel.CanInstallUpdate, Converter={StaticResource BoolToVis}}" />
              <ui:Button
                Command="{Binding ViewModel.OpenUpdateUrlCommand}"
                Content="Open release"
                Icon="{ui:SymbolIcon Open24}"
                Visibility="{Binding ViewModel.HasUpdateLink, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
            <TextBlock
              Margin="0,12,0,0"
              Style="{StaticResource PageSubtitleTextStyle}"
              Text="{Binding ViewModel.UpdateStatus, Mode=OneWay}" />
          </StackPanel>
        </ui:Card>

        <ui:Card Margin="0,0,0,12" Padding="20">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
              <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Logs" />
              <TextBlock
                Margin="0,4,0,0"
                Style="{StaticResource PageSubtitleTextStyle}"
                Text="Every action is logged. Open the folder if you need to send a log for help." />
            </StackPanel>
            <ui:Button
              Grid.Column="1"
              VerticalAlignment="Center"
              Command="{Binding ViewModel.OpenLogsCommand}"
              Content="Open logs"
              Icon="{ui:SymbolIcon DocumentBulletList24}" />
          </Grid>
        </ui:Card>

        <ui:CardExpander Margin="0,0,0,12" Icon="{ui:SymbolIcon Rocket24}">
          <ui:CardExpander.Header>
            <StackPanel>
              <TextBlock FontSize="15" FontWeight="SemiBold" Text="Game Boost configuration" />
              <TextBlock
                Margin="0,3,0,0"
                FontSize="12.5"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Pick which games trigger autopilot and which background apps Boost closes." />
            </StackPanel>
          </ui:CardExpander.Header>

          <StackPanel Margin="0,4,0,0">
            <StackPanel Orientation="Horizontal">
              <ComboBox
                Width="300"
                Margin="0,0,8,0"
                ItemsSource="{Binding ViewModel.RunningProcesses}"
                SelectedItem="{Binding ViewModel.SelectedProcess}" />
              <ui:Button
                Margin="0,0,8,0"
                Command="{Binding ViewModel.RefreshProcessListCommand}"
                Content="Refresh"
                Icon="{ui:SymbolIcon ArrowSync24}" />
            </StackPanel>
            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
              <ui:Button
                Margin="0,0,8,0"
                Command="{Binding ViewModel.AddWatchedGameCommand}"
                Content="Add as watched game"
                Icon="{ui:SymbolIcon Games24}" />
              <ui:Button
                Command="{Binding ViewModel.AddToKillListCommand}"
                Content="Add to kill-list"
                Icon="{ui:SymbolIcon DismissCircle24}" />
            </StackPanel>

            <TextBlock Margin="0,14,0,4" FontWeight="SemiBold" Text="Watched games (autopilot)" />
            <ItemsControl ItemsSource="{Binding ViewModel.WatchedGames}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,4" Padding="10,6" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{Binding ExeName}" />
                      <CheckBox
                        Grid.Column="1"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Content="Pin to P-cores"
                        IsChecked="{Binding PinToPCores, Mode=TwoWay}" />
                      <ui:Button
                        Grid.Column="2"
                        Command="{Binding DataContext.ViewModel.RemoveWatchedGameCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                        CommandParameter="{Binding}"
                        Icon="{ui:SymbolIcon DeleteDismiss24}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Margin="0,14,0,4" FontWeight="SemiBold" Text="Kill-list (closed on Boost, restarted after)" />
            <ItemsControl ItemsSource="{Binding ViewModel.KillList}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,4" Padding="10,6" Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="6">
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="12" Text="{Binding}" TextTrimming="CharacterEllipsis" />
                      <ui:Button
                        Grid.Column="1"
                        Command="{Binding DataContext.ViewModel.RemoveFromKillListCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                        CommandParameter="{Binding}"
                        Icon="{ui:SymbolIcon DeleteDismiss24}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock
              Margin="0,6,0,0"
              FontSize="11"
              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
              Text="Boost asks apps to close first, then force-closes after 5 s — save your work. Closed apps restart (de-elevated) when you un-Boost."
              TextWrapping="Wrap" />
          </StackPanel>
        </ui:CardExpander>

        <ui:Card Margin="0,0,0,12" Padding="20">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
              <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="Hold timer at logon" />
              <TextBlock
                Margin="0,4,0,0"
                Style="{StaticResource PageSubtitleTextStyle}"
                Text="{Binding ViewModel.LogonTaskLabel, Mode=OneWay}" />
            </StackPanel>
            <ui:ToggleSwitch
              Grid.Column="1"
              VerticalAlignment="Center"
              Command="{Binding ViewModel.ToggleLogonTaskCommand}"
              IsChecked="{Binding ViewModel.LogonTaskInstalled, Mode=OneWay}" />
          </Grid>
        </ui:Card>

        <ui:Card Padding="20">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
              <TextBlock Style="{StaticResource CardTitleTextStyle}" Text="About" />
              <TextBlock
                Margin="0,4,0,0"
                Style="{StaticResource PageSubtitleTextStyle}"
                Text="Helios Neo Toolkit is open source. Issues and contributions welcome." />
            </StackPanel>
            <ui:Button
              Grid.Column="1"
              VerticalAlignment="Center"
              Command="{Binding ViewModel.OpenRepoCommand}"
              Content="GitHub repo"
              Icon="{ui:SymbolIcon Code24}" />
          </Grid>
        </ui:Card>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
