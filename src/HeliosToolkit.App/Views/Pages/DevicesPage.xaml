<Page
  x:Class="HeliosToolkit.App.Views.Pages.DevicesPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:vm="clr-namespace:HeliosToolkit.App.ViewModels"
  xmlns:hw="clr-namespace:HeliosToolkit.App.Services.Hardware"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignHeight="900"
  d:DesignWidth="1100"
  Title="Devices &amp; Drivers"
  Foreground="{DynamicResource TextFillColorPrimaryBrush}">

  <Page.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <DataTemplate x:Key="DriverRowTemplate" DataType="{x:Type vm:DriverComponentViewModel}">
      <ui:Card Margin="0,0,12,10" Padding="16,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0" Margin="0,0,16,0" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <Ellipse
                Width="9"
                Height="9"
                Margin="0,1,8,0"
                VerticalAlignment="Center"
                Fill="{Binding StatusBrush}" />
              <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
              <TextBlock
                Margin="10,0,0,0"
                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                Text="{Binding VendorLine}" />
            </StackPanel>
            <TextBlock
              Margin="17,3,0,0"
              FontSize="12.5"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="{Binding StatusText}"
              TextWrapping="Wrap" />
            <TextBlock
              Margin="17,1,0,0"
              FontSize="12"
              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
              Text="{Binding MatchedDeviceLine}"
              TextWrapping="Wrap"
              Visibility="{Binding HasMatchedDevice, Converter={StaticResource BoolToVis}}" />
            <TextBlock
              Margin="17,4,0,0"
              FontSize="12"
              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
              Text="{Binding InstallNotes}"
              TextWrapping="Wrap"
              Visibility="{Binding HasInstallNotes, Converter={StaticResource BoolToVis}}" />
            <StackPanel Margin="17,6,0,0" Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
              <ProgressBar Height="6" Maximum="100" Value="{Binding Progress, Mode=OneWay}" />
            </StackPanel>
            <TextBlock
              Margin="17,4,0,0"
              FontSize="11.5"
              FontFamily="Consolas"
              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
              Text="{Binding DownloadedFileLine}"
              TextWrapping="Wrap"
              Visibility="{Binding HasDownloaded, Converter={StaticResource BoolToVis}}" />
          </StackPanel>

          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <ui:Button
              Margin="0,0,0,6"
              HorizontalAlignment="Stretch"
              Appearance="Primary"
              Command="{Binding DownloadCommand}"
              Content="Download"
              Icon="{ui:SymbolIcon ArrowDownload24}"
              Visibility="{Binding ShowDownloadButton, Converter={StaticResource BoolToVis}}" />
            <ui:Button
              Margin="0,0,0,6"
              HorizontalAlignment="Stretch"
              Appearance="Primary"
              Command="{Binding LaunchInstallerCommand}"
              Content="Launch installer"
              Icon="{ui:SymbolIcon Play24}"
              Visibility="{Binding HasDownloaded, Converter={StaticResource BoolToVis}}" />
            <ui:Button
              Margin="0,0,0,6"
              HorizontalAlignment="Stretch"
              Command="{Binding OpenFolderCommand}"
              Content="Open folder"
              Icon="{ui:SymbolIcon FolderOpen24}"
              Visibility="{Binding HasDownloaded, Converter={StaticResource BoolToVis}}" />
            <ui:Button
              Margin="0,0,0,6"
              HorizontalAlignment="Stretch"
              Command="{Binding OpenPageCommand}"
              Content="Open page"
              Icon="{ui:SymbolIcon Globe24}"
              Visibility="{Binding HasPage, Converter={StaticResource BoolToVis}}" />
            <ui:HyperlinkButton
              HorizontalAlignment="Center"
              Command="{Binding OpenNotesCommand}"
              Content="Release notes"
              Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}" />
          </StackPanel>
        </Grid>
      </ui:Card>
    </DataTemplate>

    <DataTemplate x:Key="ProblemDeviceTemplate" DataType="{x:Type hw:PnpDevice}">
      <ui:Card Margin="0,0,12,8" Padding="14,10">
        <StackPanel>
          <StackPanel Orientation="Horizontal">
            <ui:SymbolIcon
              Margin="0,0,8,0"
              Foreground="{StaticResource RiskRiskyBrush}"
              Symbol="ErrorCircle24" />
            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
            <TextBlock
              Margin="10,0,0,0"
              Foreground="{DynamicResource TextFillColorTertiaryBrush}"
              Text="{Binding PnpClass}" />
          </StackPanel>
          <TextBlock
            Margin="28,2,0,0"
            FontSize="12.5"
            Foreground="{StaticResource RiskRiskyBrush}"
            Text="{Binding ProblemText}" />
          <TextBlock
            Margin="28,2,0,0"
            FontSize="11.5"
            FontFamily="Consolas"
            Foreground="{DynamicResource TextFillColorTertiaryBrush}"
            Text="{Binding HardwareIdsText}"
            TextWrapping="Wrap" />
        </StackPanel>
      </ui:Card>
    </DataTemplate>
  </Page.Resources>

  <Grid Margin="32,24,20,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Header -->
    <Grid Grid.Row="0" Margin="0,0,12,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Style="{StaticResource PageTitleTextStyle}" Text="Devices &amp; Drivers" />
        <TextBlock
          Margin="0,4,0,0"
          Style="{StaticResource PageSubtitleTextStyle}"
          Text="{Binding ViewModel.ScanSummary, Mode=OneWay}" />
      </StackPanel>
      <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
        <ui:Button
          Margin="0,0,8,0"
          Appearance="Primary"
          Command="{Binding ViewModel.ScanCommand}"
          Content="Rescan"
          Icon="{ui:SymbolIcon ArrowClockwise24}" />
        <ui:Button
          Margin="0,0,8,0"
          Command="{Binding ViewModel.OpenAcerSupportCommand}"
          Content="Acer support page"
          Icon="{ui:SymbolIcon Globe24}" />
        <ui:Button
          Command="{Binding ViewModel.OpenDownloadsFolderCommand}"
          Content="Downloads"
          Icon="{ui:SymbolIcon FolderOpen24}" />
      </StackPanel>
    </Grid>

    <ScrollViewer Grid.Row="1" Margin="0,14,0,0" Padding="0,0,12,24" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <ui:ProgressRing
          Margin="0,24,0,24"
          HorizontalAlignment="Center"
          IsIndeterminate="True"
          Visibility="{Binding ViewModel.IsScanning, Converter={StaticResource BoolToVis}}" />

        <!-- Problem devices -->
        <ui:InfoBar
          Title="Problem devices found"
          Margin="0,0,12,10"
          IsClosable="False"
          IsOpen="{Binding ViewModel.HasProblemDevices, Mode=OneWay}"
          Message="{Binding ViewModel.ProblemBannerText, Mode=OneWay}"
          Severity="Error" />
        <ItemsControl
          ItemTemplate="{StaticResource ProblemDeviceTemplate}"
          ItemsSource="{Binding ViewModel.ProblemDevices}"
          Visibility="{Binding ViewModel.HasProblemDevices, Converter={StaticResource BoolToVis}}" />

        <!-- Driver updates -->
        <TextBlock
          Margin="0,12,0,10"
          Style="{StaticResource CardTitleTextStyle}"
          Text="Driver updates for this laptop" />
        <ItemsControl ItemTemplate="{StaticResource DriverRowTemplate}" ItemsSource="{Binding ViewModel.DriverRows}" />

        <!-- All devices -->
        <TextBlock
          Margin="0,18,0,10"
          Style="{StaticResource CardTitleTextStyle}"
          Text="All devices" />
        <ui:TextBox
          Margin="0,0,12,10"
          Icon="{ui:SymbolIcon Search24}"
          PlaceholderText="Filter by name, class or hardware ID…"
          Text="{Binding ViewModel.SearchText, UpdateSourceTrigger=PropertyChanged}" />
        <Border
          Margin="0,0,12,0"
          BorderBrush="{DynamicResource ControlElevationBorderBrush}"
          BorderThickness="1"
          CornerRadius="6">
          <ListView
            MaxHeight="420"
            ItemsSource="{Binding ViewModel.DevicesView}"
            SelectedItem="{Binding ViewModel.SelectedDevice}"
            VirtualizingPanel.IsVirtualizing="True"
            VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.View>
              <GridView>
                <GridViewColumn
                  Width="430"
                  DisplayMemberBinding="{Binding Name}"
                  Header="Device" />
                <GridViewColumn
                  Width="130"
                  DisplayMemberBinding="{Binding PnpClass}"
                  Header="Class" />
                <GridViewColumn
                  Width="130"
                  DisplayMemberBinding="{Binding DriverVersionText}"
                  Header="Driver" />
                <GridViewColumn
                  Width="100"
                  DisplayMemberBinding="{Binding DriverDateText}"
                  Header="Date" />
                <GridViewColumn
                  Width="220"
                  DisplayMemberBinding="{Binding ProblemText}"
                  Header="Problem" />
              </GridView>
            </ListView.View>
          </ListView>
        </Border>

        <!-- Selected device details -->
        <ui:Card
          Margin="0,10,12,0"
          Padding="14,10"
          Visibility="{Binding ViewModel.HasSelectedDevice, Converter={StaticResource BoolToVis}}">
          <StackPanel>
            <Grid>
              <TextBlock FontWeight="SemiBold" Text="Hardware IDs" />
              <ui:Button
                HorizontalAlignment="Right"
                Command="{Binding ViewModel.CopyHardwareIdsCommand}"
                Content="Copy"
                Icon="{ui:SymbolIcon Copy24}" />
            </Grid>
            <TextBlock
              Margin="0,6,0,0"
              FontFamily="Consolas"
              FontSize="12"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="{Binding ViewModel.SelectedHardwareIds, Mode=OneWay}"
              TextWrapping="Wrap" />
          </StackPanel>
        </ui:Card>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
