<UserControl
  x:Class="HeliosToolkit.App.Views.Controls.TweakListView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:vm="clr-namespace:HeliosToolkit.App.ViewModels"
  xmlns:conv="clr-namespace:HeliosToolkit.App.Converters"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  mc:Ignorable="d"
  d:DesignHeight="600"
  d:DesignWidth="900">

  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

    <DataTemplate x:Key="TweakItemTemplate" DataType="{x:Type vm:TweakItemViewModel}">
      <ui:Card Margin="0,0,12,10" Padding="16,12">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!-- Risk pill -->
          <Border
            Grid.Column="0"
            Height="22"
            MinWidth="86"
            Margin="0,2,16,0"
            VerticalAlignment="Top"
            Background="{Binding RiskBrush}"
            CornerRadius="11">
            <TextBlock
              Margin="10,0"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              FontSize="10.5"
              FontWeight="Bold"
              Foreground="White"
              Text="{Binding RiskLabel}" />
          </Border>

          <!-- Text -->
          <StackPanel Grid.Column="1" Margin="0,0,16,0">
            <TextBlock FontSize="14.5" FontWeight="SemiBold" Text="{Binding Name}" TextWrapping="Wrap" />
            <TextBlock
              Margin="0,4,0,0"
              FontSize="12.5"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="{Binding Description}"
              TextWrapping="Wrap" />

            <Border
              Margin="0,8,0,0"
              Padding="10,7"
              Background="#22C2403D"
              BorderBrush="{StaticResource RiskRiskyBrush}"
              BorderThickness="1"
              CornerRadius="6"
              Visibility="{Binding HasWarning, Converter={StaticResource BoolToVis}}">
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon
                  Margin="0,1,8,0"
                  VerticalAlignment="Top"
                  FontSize="15"
                  Foreground="{StaticResource RiskRiskyBrush}"
                  Symbol="Warning24" />
                <TextBlock
                  MaxWidth="640"
                  FontSize="12"
                  Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                  Text="{Binding Warning}"
                  TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
              <TextBlock
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                Text="{Binding StateText}" />
              <Border
                Margin="10,0,0,0"
                Padding="7,1"
                VerticalAlignment="Center"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                CornerRadius="4"
                Visibility="{Binding ShowRebootHint, Converter={StaticResource BoolToVis}}">
                <TextBlock
                  FontSize="10.5"
                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                  Text="{Binding RebootHint}" />
              </Border>
            </StackPanel>
          </StackPanel>

          <!-- Action -->
          <Grid Grid.Column="2" VerticalAlignment="Center">
            <ui:ToggleSwitch
              VerticalAlignment="Center"
              Command="{Binding ToggleCommand}"
              IsChecked="{Binding IsOn, Mode=TwoWay}"
              IsEnabled="{Binding IsToggleEnabled}"
              Visibility="{Binding IsInfo, Converter={StaticResource InverseBoolToVis}}" />
            <ui:Button
              VerticalAlignment="Center"
              Command="{Binding OpenLinkCommand}"
              Content="Get it"
              Icon="{ui:SymbolIcon Open24}"
              Visibility="{Binding ShowInfoLink, Converter={StaticResource BoolToVis}}" />
            <ui:ProgressRing
              Width="26"
              Height="26"
              VerticalAlignment="Center"
              IsIndeterminate="True"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
          </Grid>
        </Grid>
      </ui:Card>
    </DataTemplate>

    <Style x:Key="CategoryHeaderStyle" TargetType="GroupItem">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="GroupItem">
            <StackPanel>
              <TextBlock
                Margin="2,14,0,8"
                FontSize="13"
                FontWeight="Bold"
                Foreground="{StaticResource PredatorAccentBrush}"
                Text="{Binding Name}" />
              <ItemsPresenter />
            </StackPanel>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <ItemsControl ItemTemplate="{StaticResource TweakItemTemplate}" ItemsSource="{Binding}">
    <ItemsControl.GroupStyle>
      <GroupStyle ContainerStyle="{StaticResource CategoryHeaderStyle}" />
    </ItemsControl.GroupStyle>
  </ItemsControl>
</UserControl>
